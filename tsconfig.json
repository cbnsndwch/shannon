{
    "compilerOptions": {
        "target": "ES2022",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "rootDir": ".",
        "outDir": "dist",
        "strict": true,
        "lib": ["ESNext"],
        "types": ["node"],
        "skipLibCheck": true,
        "declaration": false,
        "sourceMap": false,
        "forceConsistentCasingInFileNames": true
    },
    "include": ["src/**/*", "test/**/*"]
}
